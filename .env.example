# Browser-safe Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# TanStack Start server configuration
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional global key. A signed-in user can instead add a personal key in Configuration IA.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Server/Edge worker secrets — never prefix these with VITE_.
SPORTS_PROVIDER_API_KEY=
PREDICTION_ENGINE_SHARED_SECRET=
FIRECRAWL_API_KEY=

# Supabase deployment only (CI/Codex environment, never the frontend)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
